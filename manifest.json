{
  "manifest_version": 3,
  "name": "Fresh Tab",
  "version": "1.0.2",
  "description": "Hard reload: wipe all site data for current page",
  "homepage_url": "https://github.com/Dobrunia/fresh-tab",
  "author": "Dobrunia",
  "permissions": [
    "activeTab",
    "browsingData",
    "cookies",
    "scripting",
    "tabs",
    "notifications"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "fresh-tab@dobrunia.github",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_title": "Hard reload (clear all site data)",
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    }
  },
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  }
}
